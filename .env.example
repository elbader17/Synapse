# Environment Configuration Example
# Copy this file to .env and update with your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=medical_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=medical_records
DB_SSL_MODE=require

# ===========================================
# JWT CONFIGURATION
# ===========================================
# IMPORTANTE: En producción, usar una clave segura de al menos 32 caracteres
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRY=168h

# ===========================================
# ENCRYPTION CONFIGURATION
# ===========================================
# IMPORTANTE: La clave de encryption debe ser exactamente 64 caracteres hex (256 bits)
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Rate limit requests per minute
RATE_LIMIT=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# AUDIT CONFIGURATION
# ===========================================
# HIPAA requiere retención mínima de 6 años (2190 días)
AUDIT_RETENTION_DAYS=2190

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development